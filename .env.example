# ── Required API Keys ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ASSEMBLYAI_API_KEY=...

# ── Database ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/vidpipeline

# ── Storage ──────────────────────────────────────────────────────
# local  → files stored in ./storage (good for dev)
# r2     → Cloudflare R2 (production)
STORAGE_TYPE=local

# Only needed when STORAGE_TYPE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=video-pipeline
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Domain ───────────────────────────────────────────────────────
# For local dev: localhost
# For prod: yourdomain.com  (Traefik will auto-issue SSL)
DOMAIN=localhost

# Optional frontend overrides
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://backend:8000

# ── App Settings ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
FILE_TTL_HOURS=24
MAX_SHORTS=8
