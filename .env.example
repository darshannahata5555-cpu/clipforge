# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ASSEMBLYAI_API_KEY=...

# ── Database ──────────────────────────────────────────────────────────────────
# Railway auto-provides DATABASE_URL — only needed for local dev / VPS
POSTGRES_PASSWORD=changeme

# ── Storage ───────────────────────────────────────────────────────────────────
# local  → files stored in ./storage  (dev / VPS with volume)
# r2     → Cloudflare R2              (recommended for Railway)
STORAGE_TYPE=local

# Only needed when STORAGE_TYPE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=video-pipeline
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Domain (VPS / Traefik only) ───────────────────────────────────────────────
DOMAIN=localhost

# ── App limits ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
MAX_SHORTS=3
